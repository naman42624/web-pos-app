# MongoDB Connection (MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
# Get this from MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/pos-system?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# App Environment
NODE_ENV=production

# Optional: Custom ping message
PING_MESSAGE=pong
